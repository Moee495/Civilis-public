# Civilis limited-mainnet release template
# Copy this file to a private env file and fill the deployment-specific values.

DATABASE_URL=postgresql://civilis:civilis@localhost:5432/civilis

PORT=3001
AUTO_START_WORLD=false

LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_API_URL=
LLM_MODEL=

LLM_SOCIAL_PROVIDER=
LLM_SOCIAL_API_KEY=
LLM_SOCIAL_API_URL=
LLM_SOCIAL_MODEL=

LLM_FAREWELL_PROVIDER=
LLM_FAREWELL_API_KEY=
LLM_FAREWELL_API_URL=
LLM_FAREWELL_MODEL=

LLM_OBSERVER_PROVIDER=
LLM_OBSERVER_API_KEY=
LLM_OBSERVER_API_URL=
LLM_OBSERVER_MODEL=

X_LAYER_NETWORK=mainnet
X_LAYER_CHAIN_ID=196
X_LAYER_MAINNET_RPC=https://rpc.xlayer.tech
X_LAYER_RPC=https://rpc.xlayer.tech
X402_PAYMENT_MODE=direct_wallet
CIVILIS_STRICT_MODE=true

DEPLOYER_PRIVATE_KEY=your-deployer-private-key
TREASURY_PRIVATE_KEY=your-treasury-private-key
TREASURY_ADDRESS=0xYourTreasuryAddress
USDT_ADDRESS=0xYourUsdtAddress

ACP_PRIVATE_KEY=
CIVILIS_COMMERCE_PRIVATE_KEY=
ERC8004_IDENTITY_PRIVATE_KEY=
ERC8004_REPUTATION_PRIVATE_KEY=
ERC8004_VALIDATION_PRIVATE_KEY=
SOUL_PRIVATE_KEY=

OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Must be an on-chain x402 contract address for strict mainnet preflight.
X402_SERVICE_ADDRESS=

ACP_V2_CONTRACT_ADDRESS=0xBEf97c569a5b4a82C1e8f53792eC41c988A4316e
CIVILIS_COMMERCE_V2_ADDRESS=0x7bac782C23E72462C96891537C61a4C86E9F086e
ERC8004_IDENTITY_V2_ADDRESS=0xC9C992C0e2B8E1982DddB8750c15399D01CF907a
ERC8004_REPUTATION_V2_ADDRESS=0xD8499b9A516743153EE65382f3E2C389EE693880
ERC8004_VALIDATION_V2_ADDRESS=0x0CC71B9488AA74A8162790b65592792Ba52119fB

# Optional explicit mapper address if it should differ from the commerce signer.
CIVILIS_COMMERCE_MAPPER_ADDRESS=

# Keep legacy aliases blank in the release template to avoid mixed-state preflight.
ACP_CONTRACT_ADDRESS=
CIVILIS_COMMERCE_ADDRESS=
ERC8004_IDENTITY_ADDRESS=
ERC8004_REPUTATION_ADDRESS=
ERC8004_VALIDATION_ADDRESS=

# Required only if soul archive mode is on-chain mint.
SOUL_NFT_ADDRESS=
SOUL_ARCHIVE_MODE=hash_only
MAINNET_EPOCH_ENABLED=true
MAINNET_EPOCH_START_AT=2026-03-23T00:00:00+08:00
MAINNET_EPOCH_START_TICK=114

CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

SERVER_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

ALLOWED_ORIGINS=http://localhost:3000
OKX_PAYMENTS_LEGACY_FALLBACK=false
