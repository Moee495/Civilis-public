# Core payment rail
USDT_ADDRESS=REPLACE_WITH_DEPLOYED_USDT_ADDRESS
X402_SERVICE_ADDRESS=REPLACE_WITH_DEPLOYED_X402_SERVICE_ADDRESS

# v2 contract layer (preferred)
ACP_V2_CONTRACT_ADDRESS=REPLACE_WITH_DEPLOYED_ACPV2_ADDRESS
CIVILIS_COMMERCE_V2_ADDRESS=REPLACE_WITH_DEPLOYED_CIVILIS_COMMERCE_V2_ADDRESS
ERC8004_IDENTITY_V2_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_IDENTITY_V2_ADDRESS
ERC8004_REPUTATION_V2_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_REPUTATION_V2_ADDRESS
ERC8004_VALIDATION_V2_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_VALIDATION_V2_ADDRESS
CIVILIS_COMMERCE_MAPPER_ADDRESS=REPLACE_WITH_RUNTIME_MAPPER_ADDRESS

# Mainnet canary preparation rules:
# - these five v2 address keys must be filled directly for production-target preflight
# - leaving only legacy alias keys populated will surface as mixed/blocker
# - mapper address may be derived from private key at runtime, but explicit population is preferred for checklist review

# Transitional aliases (optional; keeping these populated will surface as mixed/alias usage in preflight)
ACP_CONTRACT_ADDRESS=REPLACE_WITH_DEPLOYED_ACPV2_ADDRESS
CIVILIS_COMMERCE_ADDRESS=REPLACE_WITH_DEPLOYED_CIVILIS_COMMERCE_V2_ADDRESS
ERC8004_IDENTITY_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_IDENTITY_V2_ADDRESS
ERC8004_REPUTATION_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_REPUTATION_V2_ADDRESS
ERC8004_VALIDATION_ADDRESS=REPLACE_WITH_DEPLOYED_ERC8004_VALIDATION_V2_ADDRESS

# Non-v2 legacy modules still present in the repo
AGENT_REGISTRY_ADDRESS=REPLACE_WITH_DEPLOYED_AGENT_REGISTRY_ADDRESS
SOCIAL_HUB_ADDRESS=REPLACE_WITH_DEPLOYED_SOCIAL_HUB_ADDRESS
ARENA_GAME_ADDRESS=REPLACE_WITH_DEPLOYED_ARENA_GAME_ADDRESS
TREASURY_CONTRACT_ADDRESS=REPLACE_WITH_DEPLOYED_TREASURY_CONTRACT_ADDRESS
