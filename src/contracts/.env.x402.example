# x402-only template. v2 protocol/trust addresses belong in .env.deployed.example.
USDT_ADDRESS=REPLACE_WITH_X402_USDT_ADDRESS
X402_SERVICE_ADDRESS=REPLACE_WITH_X402_SERVICE_ADDRESS

# Optional cross-reference placeholders for full-stack dry runs
ACP_V2_CONTRACT_ADDRESS=REPLACE_WITH_OPTIONAL_ACPV2_ADDRESS
CIVILIS_COMMERCE_V2_ADDRESS=REPLACE_WITH_OPTIONAL_CIVILIS_COMMERCE_V2_ADDRESS
ERC8004_IDENTITY_V2_ADDRESS=REPLACE_WITH_OPTIONAL_ERC8004_IDENTITY_V2_ADDRESS
ERC8004_REPUTATION_V2_ADDRESS=REPLACE_WITH_OPTIONAL_ERC8004_REPUTATION_V2_ADDRESS
ERC8004_VALIDATION_V2_ADDRESS=REPLACE_WITH_OPTIONAL_ERC8004_VALIDATION_V2_ADDRESS

# This file is not enough for mainnet canary readiness on its own.
# Production-target preflight still requires the full v2 protocol/trust address set,
# signer roster, and role/kernel validation.
