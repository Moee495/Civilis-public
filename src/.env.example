# Civilis local environment template
# Copy this file to .env and fill the values for your own environment.

# Database
DATABASE_URL=postgresql://civilis:civilis@localhost:5432/civilis

# Server
PORT=3001
AUTO_START_WORLD=true

# LLM defaults
# Supported providers: openai | anthropic | deepseek | ollama
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_API_URL=
LLM_MODEL=
#
# Provider defaults:
#   openai    -> https://api.openai.com/v1       -> gpt-4o-mini
#   anthropic -> https://api.anthropic.com       -> claude-sonnet-4-20250514
#   deepseek  -> https://api.deepseek.com        -> deepseek-chat
#   ollama    -> http://localhost:11434          -> llama3
#
# OpenAI-compatible endpoints are also supported by setting:
#   LLM_PROVIDER=openai
#   LLM_API_URL=<provider endpoint>
#   LLM_MODEL=<provider model>

# Optional role-specific LLM overrides
LLM_SOCIAL_PROVIDER=
LLM_SOCIAL_API_KEY=
LLM_SOCIAL_API_URL=
LLM_SOCIAL_MODEL=

LLM_FAREWELL_PROVIDER=
LLM_FAREWELL_API_KEY=
LLM_FAREWELL_API_URL=
LLM_FAREWELL_MODEL=

LLM_OBSERVER_PROVIDER=
LLM_OBSERVER_API_KEY=
LLM_OBSERVER_API_URL=
LLM_OBSERVER_MODEL=

# X Layer defaults
X_LAYER_RPC=https://testrpc.xlayer.tech/terigon
X_LAYER_NETWORK=testnet
X_LAYER_CHAIN_ID=1952
X_LAYER_MAINNET_RPC=https://rpc.xlayer.tech
CIVILIS_STRICT_MODE=true
DEPLOYER_PRIVATE_KEY=your-deployer-private-key

# Treasury / signer roles
TREASURY_PRIVATE_KEY=your-treasury-private-key
TREASURY_ADDRESS=0xYourTreasuryAddress
USDT_ADDRESS=0xYourUsdtAddress

# Optional dedicated signers to reduce nonce contention on mainnet
ACP_PRIVATE_KEY=
CIVILIS_COMMERCE_PRIVATE_KEY=
ERC8004_IDENTITY_PRIVATE_KEY=
ERC8004_REPUTATION_PRIVATE_KEY=
ERC8004_VALIDATION_PRIVATE_KEY=
SOUL_PRIVATE_KEY=

# x402
X402_SERVICE_ADDRESS=

# v2 contracts (preferred)
ACP_V2_CONTRACT_ADDRESS=
CIVILIS_COMMERCE_V2_ADDRESS=
ERC8004_IDENTITY_V2_ADDRESS=
ERC8004_REPUTATION_V2_ADDRESS=
ERC8004_VALIDATION_V2_ADDRESS=

# Optional runtime mapper role
CIVILIS_COMMERCE_MAPPER_ADDRESS=

# Transitional legacy aliases. Keeping only alias keys populated will surface as
# mixed / blocker in strict mainnet preflight.
ACP_CONTRACT_ADDRESS=
CIVILIS_COMMERCE_ADDRESS=
ERC8004_IDENTITY_ADDRESS=
ERC8004_REPUTATION_ADDRESS=
ERC8004_VALIDATION_ADDRESS=

# Optional ERC-8183 hooks
ACP_HOOK_ARENA=
ACP_HOOK_PREDICTION=
ACP_HOOK_COMMONS=
ACP_HOOK_INTEL=
ACP_HOOK_SPLIT=

# Other on-chain modules
SOUL_NFT_ADDRESS=
SOUL_ARCHIVE_MODE=

# Explicit soul archive mode:
# - onchain_mint requires SOUL_NFT_ADDRESS
# - hash_only records only the soul hash without minting an NFT
MAINNET_EPOCH_ENABLED=
MAINNET_EPOCH_START_AT=
MAINNET_EPOCH_START_TICK=

# Coinbase Developer Platform (optional)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# OKX Agentic Wallet / TEE credentials
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Runtime URLs
SERVER_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Testnet batch funding defaults
AGENT_TESTNET_FUND_AMOUNT=10
TREASURY_TESTNET_FUND_AMOUNT=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# When false (default), only call the official OKX x402 endpoints.
# Set to true only for temporary compatibility debugging.
OKX_PAYMENTS_LEGACY_FALLBACK=false
